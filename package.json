{
  "name": "slooze-backend",
  "version": "1.0.0",
  "description": "Role-based food ordering backend for Slooze take-home challenge",
  "main": "src/main.ts",
  "scripts": {
    "start": "npx ts-node src/main.ts",
    "start:dev": "npx ts-node src/main.ts",
    "build": "npx prisma generate && npx prisma db push && npx ts-node prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "npx ts-node prisma/seed.ts",
    "setup": "npx prisma generate && npx prisma db push && npx ts-node prisma/seed.ts && npx ts-node src/main.ts"
  },
  "dependencies": {
    "@nestjs/apollo": "^12.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/graphql": "^12.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@apollo/server": "^4.9.0",
    "@prisma/client": "^5.0.0",
    "graphql": "^16.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "bcryptjs": "^2.4.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  }
}